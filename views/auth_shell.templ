package views

templ AuthShell(title string) {
	@Base(title) {
		<main class="hero min-h-screen bg-base-200">
			<div class="hero-content flex-col w-full">
				<div class="card bg-base-100 w-full max-w-sm shrink-0 shadow-2xl">
					<div class="card-body">
						{ children... }
					</div>
				</div>
			</div>
		</main>
	}
}
